{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "灵枢 LingShu",
  "version": "1.0.0",
  "identifier": "com.lingshu.desktop",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "灵枢 LingShu — 个人助理",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      },
      {
        "label": "pet",
        "title": "灵枢",
        "url": "/pet.html",
        "width": 200,
        "height": 260,
        "x": 40,
        "y": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/lingshu-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "LingShu Dev"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
