{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "\u7075\u67a2 LingShu",
  "version": "0.1.0",
  "identifier": "com.lingshu.desktop",
  "build": {
    "beforeDevCommand": "npm run --prefix /Users/ymqz/projects/PA/frontend dev",
    "beforeBuildCommand": "npm run --prefix /Users/ymqz/projects/PA/frontend build",
    "frontendDist": "/Users/ymqz/projects/PA/frontend/dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "\u7075\u67a2 LingShu \u2014 \u4e2a\u4eba\u52a9\u7406",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      },
      {
        "label": "pet",
        "title": "\u7075\u67a2",
        "url": "/pet.html",
        "width": 200,
        "height": 260,
        "x": 40,
        "y": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
