{
  "identifier": "default",
  "description": "Default capability set for LingShu desktop app",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill"
  ]
}
